{
	"extends": "@tsconfig/node22/tsconfig.json",
	"compilerOptions": {
		"typeRoots": [
			"src/@types",
			"node_modules/@types"
		],
		"outDir": "./dist",
		"rootDir": "./src",
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
	},
	"include": [
		"**/*.ts"
	],
	"exclude": [
		"./dist",
		"node_modules"
	]
}